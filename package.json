{
  "name": "background-image-cropper",
  "version": "1.0.0",
  "description": "Optimize CSS background-image downloads by cropping and scaling each layer to exactly the pixels the browser actually paints. Framework-agnostic, zero runtime dependencies, works in every browser.",
  "keywords": [
    "background-image",
    "css",
    "image",
    "crop",
    "resize",
    "responsive-images",
    "performance",
    "cdn",
    "lazy",
    "devicePixelRatio"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lsobolew/background-image-cropper.git"
  },
  "bugs": {
    "url": "https://github.com/lsobolew/background-image-cropper/issues"
  },
  "homepage": "https://github.com/lsobolew/background-image-cropper#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/background-image-cropper.global.js",
  "jsdelivr": "./dist/background-image-cropper.global.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test --experimental-strip-types \"test/**/*.test.ts\"",
    "test:watch": "node --test --watch --experimental-strip-types \"test/**/*.test.ts\"",
    "demo": "node scripts/serve-demo.mjs",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.20.1",
    "semantic-release": "^25.0.8",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  },
  "allowScripts": {
    "esbuild@0.27.7": true
  }
}
